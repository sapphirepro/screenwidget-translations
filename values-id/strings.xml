    <string name="lbl_addwidget"><![CDATA[
        1. Tekan tombol beranda untuk membuka layar beranda.<br/>
        2. Tekan dan tahan pada area yang tidak ditempati ikon.<br/>
        3. Pilih "widget".<br/>
        4. Gulir ke widget "ScreenWidget".<br/>
        5. Seret dan lepas ke layar beranda pada posisi yang diinginkan.<br/>
        6. Ketuk widget untuk mengubah mode batas waktu layar.\n]]>
    </string>
    <string name="lbl_addtile_header">Menambahkan Tile Pengaturan Cepat</string>
    <string name="lbl_addtile1">1. Buka panel notifikasi.</string>
    <string name="lbl_addtile2">2. Geser ke bawah dari atas untuk membuka panel Pengaturan Cepat.</string>
    <string name="lbl_addtile3">3. Ketuk tombol EDIT.</string>
    <string name="lbl_addtile4">4. Seret tile bernama "Screen Timeout" ke panel Pengaturan Cepat.</string>
    <string name="lbl_addtile5">5. Ketuk kembali dan tile siap digunakan.</string>
    <string name="lbl_addtile"><![CDATA[
        1. Buka panel notifikasi.<br/>
        2. Geser ke bawah dari atas untuk membuka panel Pengaturan Cepat.<br/>
        3. Ketuk tombol EDIT.<br/>
        4. Seret tile bernama "Screen Timeout" ke panel Pengaturan Cepat.<br/>
        5. Ketuk kembali dan tile siap digunakan.\n]]>
    </string>

