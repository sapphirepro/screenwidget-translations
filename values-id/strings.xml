    <string name="lbl_addwidget_header">Menambahkan widget ke layar beranda</string>
    <string name="lbl_addwidget1">1. Tekan tombol beranda untuk membuka layar beranda.</string>
    <string name="lbl_addwidget2">2. Tekan dan tahan pada area yang tidak ditempati ikon.</string>
    <string name="lbl_addwidget3">3. Pilih "widget".</string>
    <string name="lbl_addwidget4">4. Gulir ke widget "ScreenWidget".</string>
    <string name="lbl_addwidget5">5. Seret dan lepas ke layar beranda pada posisi yang diinginkan.</string>
