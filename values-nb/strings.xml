    <string name="lbl_permissions">Du må gi appen tillatelse til å endre innstillinger før den fungerer. Den eneste innstillingen den endrer er skjermens tidsavbrudd.</string>
    <string name="btn_permissions">Konfigurer</string>
    <string name="lbl_addwidget_header">Legge til widget på startskjermen</string>
    <string name="lbl_addwidget1">1. Trykk på hjem-knappen for å gå til startskjermen.</string>
    <string name="lbl_addwidget2">2. Hold fingeren nede på et område som ikke er opptatt av et ikon.</string>
    <string name="lbl_addwidget3">3. Velg "widgets".</string>
    <string name="lbl_addwidget4">4. Bla til widgeten "ScreenWidget".</string>
    <string name="lbl_addwidget5">5. Dra og slipp den på ønsket sted på startskjermen.</string>
    <string name="lbl_addwidget6">6. Trykk på widgeten for å endre skjermens tidsavbruddsmodus.</string>
    <string name="lbl_addwidget"><![CDATA[
        1. Trykk på hjem-knappen for å gå til startskjermen.<br/>
        2. Hold fingeren nede på et område som ikke er opptatt av et ikon.<br/>
        3. Velg "widgets".<br/>
        4. Bla til widgeten "ScreenWidget".<br/>
        5. Dra og slipp den på ønsket sted på startskjermen.<br/>
        6. Trykk på widgeten for å endre skjermens tidsavbruddsmodus.\n]]>
    </string>
    <string name="lbl_addtile_header">Legge til hurtiginnstillingsflis</string>
    <string name="lbl_addtile1">1. Åpne varselpanelet.</string>
    <string name="lbl_addtile2">2. Sveip ned fra toppen for å åpne Hurtiginnstillinger-panelet.</string>
    <string name="lbl_addtile3">3. Trykk på REDIGER-knappen.</string>
    <string name="lbl_addtile4">4. Dra flisen med navnet "Screen Timeout" inn i Hurtiginnstillinger-panelet.</string>
    <string name="lbl_addtile5">5. Trykk tilbake, så er flisen klar til bruk.</string>
    <string name="lbl_addtile"><![CDATA[
        1. Åpne varselpanelet.<br/>
        2. Sveip ned fra toppen for å åpne Hurtiginnstillinger-panelet.<br/>
        3. Trykk på REDIGER-knappen.<br/>
        4. Dra flisen med navnet "Screen Timeout" inn i Hurtiginnstillinger-panelet.<br/>
        5. Trykk tilbake, så er flisen klar til bruk.\n]]>
    </string>

